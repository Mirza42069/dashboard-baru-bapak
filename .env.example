# Backend database connection. Use the RLS application role, not a superuser.
DATABASE_URL=postgresql://app_rls:app@localhost:5432/app

# Replace this with a long random secret before running outside local development.
JWT_SECRET=dev-insecure-secret-change-me

# Backend API port used by Vite's /api proxy.
PORT=3001

# Refresh cookies are secure automatically in production. Set explicitly if needed.
COOKIE_SECURE=false

# Auth token lifetimes in seconds.
ACCESS_TTL_S=900
REFRESH_TTL_S=2592000
